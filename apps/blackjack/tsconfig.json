{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "types": ["vite/client"],
    "paths": {
      "@/*": ["./src/*"],
      "@/domain/*": ["./src/domain/*"],
      "@/app/*": ["./src/app/*"],
      "@/ui/*": ["./src/ui/*"],
      "@games/app-hook-utils": ["../../packages/app-hook-utils/src/index.ts"],
      "@games/card-deck-core": ["../../packages/card-deck-core/src/index.ts"],
      "@games/card-deck-system": ["../../packages/card-deck-system/src/index.ts"],
      "@games/common": ["../../packages/common/src/index.ts"],
      "@games/domain-shared": ["../../packages/domain-shared/src/index.ts"],
      "@games/shared-api-client": ["../../packages/shared-api-client/src/index.ts"],
      "@games/shared-config": ["../../packages/shared-config/src/index.ts"],
      "@games/shared-hooks": ["../../packages/shared-hooks/src/index.ts"],
      "@games/shared-sanitizers": ["../../packages/shared-sanitizers/src/index.ts"],
      "@games/shared-validators": ["../../packages/shared-validators/src/index.ts"],
      "@games/sound-context": ["../../packages/sound-context/src/index.ts"],
      "@games/storage-utils": ["../../packages/storage-utils/src/index.ts"],
      "@games/theme-context": ["../../packages/theme-context/src/index.ts"]
    }
  },
  "include": ["src"],
  "references": [{ "path": "../../tsconfig.json" }]
}
