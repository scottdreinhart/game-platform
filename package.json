{
  "name": "lights-out",
  "version": "1.0.0",
  "description": "Lights Out",
  "type": "module",
  "private": true,
  "license": "PROPRIETARY",
  "author": "Scott Reinhart",
  "packageManager": "pnpm@10.31.0",
  "engines": {
    "node": "24.14.0",
    "npm": "11.9.0",
    "pnpm": "10.31.0"
  },
  "main": "electron/main.js",
  "scripts": {
    "start": "vite --host",
    "dev": "kill-port 5173  || true; vite --host",
    "build": "vite build",
    "preview": "vite preview",
    "build:preview": "pnpm build && pnpm preview",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "lint:scope:app": "eslint src/app",
    "lint:scope:domain": "eslint src/domain",
    "lint:scope:ui": "eslint src/ui",
    "lint:scope:infrastructure": "eslint src/infrastructure",
    "lint:scope:wasm": "eslint src/wasm",
    "lint:scope:workers": "eslint src/workers",
    "lint:scope:all": "pnpm lint:scope:app && pnpm lint:scope:domain && pnpm lint:scope:ui && pnpm lint:scope:infrastructure && pnpm lint:scope:wasm && pnpm lint:scope:workers",
    "lint:type:a11y": "node scripts/lint-segmented.mjs --segment=a11y",
    "lint:type:security": "node scripts/lint-segmented.mjs --segment=security",
    "lint:type:hooks": "node scripts/lint-segmented.mjs --segment=hooks",
    "lint:type:react": "node scripts/lint-segmented.mjs --segment=react",
    "lint:type:boundaries": "node scripts/lint-segmented.mjs --segment=boundaries",
    "lint:type:typescript": "node scripts/lint-segmented.mjs --segment=typescript",
    "lint:type:core": "node scripts/lint-segmented.mjs --segment=core",
    "lint:type:all": "pnpm lint:type:a11y && pnpm lint:type:security && pnpm lint:type:hooks && pnpm lint:type:react && pnpm lint:type:boundaries && pnpm lint:type:typescript && pnpm lint:type:core",
    "lint:deep": "node scripts/lint-segmented.mjs --segment=all --scope=all",
    "lint:filewise:app": "node scripts/lint-filewise.mjs --scope=src/app",
    "lint:filewise:domain": "node scripts/lint-filewise.mjs --scope=src/domain",
    "lint:filewise:ui": "node scripts/lint-filewise.mjs --scope=src/ui",
    "lint:filewise:infrastructure": "node scripts/lint-filewise.mjs --scope=src/infrastructure",
    "lint:filewise:wasm": "node scripts/lint-filewise.mjs --scope=src/wasm",
    "lint:filewise:workers": "node scripts/lint-filewise.mjs --scope=src/workers",
    "lint:filewise:all": "pnpm lint:filewise:app && pnpm lint:filewise:domain && pnpm lint:filewise:ui && pnpm lint:filewise:infrastructure && pnpm lint:filewise:wasm && pnpm lint:filewise:workers",
    "lint:all": "pnpm lint:scope:all && pnpm lint:type:all",
    "lint:ci:fast": "pnpm lint:filewise:app && pnpm lint:filewise:ui && pnpm typecheck",
    "lint:ci:full": "node scripts/run-quality-gates.mjs --full",
    "quality:fast": "pnpm lint:ci:fast",
    "quality:full": "node scripts/run-quality-gates.mjs --full",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "typecheck": "tsc",
    "check": "pnpm lint && pnpm format:check && pnpm typecheck",
    "fix": "pnpm lint:fix && pnpm format",
    "validate": "pnpm check && pnpm build",
    "clean": "rimraf dist release",
    "clean:node": "rimraf node_modules",
    "clean:all": "rimraf dist release node_modules",
    "reinstall": "pnpm clean:all && pnpm install",
    "prebuild": "pnpm clean",
    "electron:dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "vite build && electron-builder",
    "electron:build:win": "vite build && electron-builder --win",
    "electron:build:linux": "vite build && electron-builder --linux",
    "electron:build:mac": "vite build && electron-builder --mac",
    "electron:preview": "pnpm build && electron .",
    "cap:init:android": "pnpm exec cap add android",
    "cap:init:ios": "pnpm exec cap add ios",
    "cap:sync": "vite build && pnpm exec cap sync",
    "cap:open:android": "pnpm exec cap open android",
    "cap:open:ios": "pnpm exec cap open ios",
    "cap:run:android": "pnpm exec cap run android",
    "cap:run:ios": "pnpm exec cap run ios",
    "wasm:build": "node scripts/build-wasm.js",
    "wasm:build:debug": "node scripts/build-wasm.js --debug",
    "check:input": "bash scripts/check-input-controls.sh",
    "test:a11y": "playwright test --config=playwright.config.ts",
    "test:a11y:debug": "playwright test --config=playwright.config.ts --debug",
    "test:lighthouse": "node scripts/test-lighthouse.js",
    "test:a11y:ui": "pnpm test:lighthouse && pnpm test:a11y",
    "commit": "pnpm exec cz"
  },
  "dependencies": {
    "@capacitor/core": "8.2.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@capacitor/app": "8.0.1",
    "@capacitor/cli": "8.2.0",
    "@capacitor/keyboard": "8.0.1",
    "@capacitor/status-bar": "8.0.1",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.58.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "assemblyscript": "0.28.10",
    "commitizen": "^4.3.1",
    "concurrently": "9.2.1",
    "cz-conventional-changelog": "^3.3.0",
    "electron": "41.0.2",
    "electron-builder": "26.8.1",
    "eslint": "10.0.3",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-boundaries": "5.4.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-security": "^4.0.0",
    "kill-port": "2.0.1",
    "lighthouse": "13.0.3",
    "playwright": "1.58.2",
    "prettier": "3.8.1",
    "prettier-plugin-organize-imports": "4.3.0",
    "rimraf": "6.1.3",
    "rollup-plugin-visualizer": "5.14.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.0",
    "vite": "8.0.0",
    "wait-on": "9.0.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "electron-winstaller",
      "esbuild"
    ]
  },
  "build": {
    "appId": "com.scottreinhart.lightsout",
    "productName": "Lights Out",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": [
        "portable"
      ],
      "signAndEditExecutable": false
    },
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  },
  "commitizen": {
    "path": "cz-conventional-changelog"
  }
}
